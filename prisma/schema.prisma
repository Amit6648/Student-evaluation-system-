// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Teacher {
  teacher_id String      @id @default(uuid())
  name       String
  email      String      @unique
  classrooms Classroom[]
}

model Classroom {
  class_id      String       @id @default(uuid())
  dept_info     String
  class_name    String
  semester      String?
  academic_year String?
  teacher_id    String
  teacher       Teacher      @relation(fields: [teacher_id], references: [teacher_id])
  enrollments   Enrollment[]
}

model Student {
  student_id  String       @id @default(uuid())
  name        String
  roll_no     String       @unique
  enrollments Enrollment[]
}

model Enrollment {
  id         String    @id @default(uuid())
  marks      Float?
  student_id String
  class_id   String
  student    Student   @relation(fields: [student_id], references: [student_id])
  classroom  Classroom @relation(fields: [class_id], references: [class_id])

  @@unique([student_id, class_id])
}
