// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}



model School {
  id      String   @id @default(uuid())
  name    String
  courses Course[]
}

model Course {
  id        String    @id @default(uuid())
  school_id String
  name      String
  school    School    @relation(fields: [school_id], references: [id])
  subjects  Subject[]
  users     User[]
}



model Subject {
  id                String           @id @default(uuid())
  course_id         String
  name              String
  semester_number   Int
  course            Course           @relation(fields: [course_id], references: [id])
  virtual_classes   VirtualClass[]
}

model User {
  id               String            @id @default(uuid())
  email            String?           @unique
  password         String?
  name             String
  role             String
  course_id        String?
  roll_no          String?           @unique
  current_semester Int?
  section          String?
  course           Course?           @relation(fields: [course_id], references: [id])
  taught_classes   VirtualClass[]    @relation("TeacherClasses")
  enrollments      ClassEnrollment[]
}

model VirtualClass {
  id            String            @id @default(uuid())
  subject_id    String
  teacher_id    String
  academic_year String
  section       String?
  subject       Subject           @relation(fields: [subject_id], references: [id])
  teacher       User              @relation("TeacherClasses", fields: [teacher_id], references: [id])
  enrollments   ClassEnrollment[]
}

model ClassEnrollment {
  id               String       @id @default(uuid())
  virtual_class_id String
  student_id       String
  group_label      String
  virtual_class    VirtualClass @relation(fields: [virtual_class_id], references: [id])
  student          User         @relation(fields: [student_id], references: [id])
  evaluations      Evaluation[]

  @@unique([virtual_class_id, student_id])
}

model Evaluation {
  id                    String          @id @default(uuid())
  enrollment_id         String
  eval_name             String
  fundamental_knowledge Float?
  core_skills           Float?
  communication_skills  Float?
  soft_skills           Float?
  evaluation_date       DateTime
  remarks               String?
  enrollment            ClassEnrollment @relation(fields: [enrollment_id], references: [id])

  @@unique([enrollment_id, evaluation_date])
}
